{
  "$schema": "https://unpkg.com/fallow-cli/schema.json",
  "ignoreDependencies": [
    "@nx-js/observer-util",
    "@risingstack/react-easy-state",
    "tailwindcss-animate"
  ],
  "ignorePatterns": [
    "selene-plugins/_vendor_screenshot_rocks/**"
  ],
  "ignoreExports": [
    {
      "file": "lib/db/sqlite-character-schema.ts",
      "exports": [
        "charactersRelations",
        "characterImagesRelations",
        "agentDocumentsRelations",
        "agentDocumentChunksRelations",
        "agentSyncFoldersRelations",
        "agentSyncFilesRelations",
        "channelConnectionsRelations",
        "channelConversationsRelations",
        "channelMessagesRelations"
      ]
    },
    {
      "file": "lib/db/sqlite-observability-schema.ts",
      "exports": [
        "agentRunsRelations",
        "agentRunEventsRelations",
        "promptTemplatesRelations",
        "promptVersionsRelations"
      ]
    },
    {
      "file": "lib/db/sqlite-plugins-schema.ts",
      "exports": [
        "pluginsRelations",
        "agentPluginsRelations",
        "pluginHooksRelations",
        "pluginMcpServersRelations",
        "pluginLspServersRelations",
        "pluginFilesRelations",
        "pluginSkillRevisionsRelations",
        "marketplacesRelations"
      ]
    },
    {
      "file": "lib/db/sqlite-schema-base.ts",
      "exports": [
        "usersRelations",
        "sessionsRelations",
        "messagesRelations",
        "toolRunsRelations",
        "webBrowseEntriesRelations",
        "imagesRelations"
      ]
    },
    {
      "file": "lib/db/sqlite-skills-schema.ts",
      "exports": [
        "skillsRelations",
        "skillVersionsRelations",
        "skillFilesRelations"
      ]
    },
    {
      "file": "lib/db/sqlite-voice-schema.ts",
      "exports": [
        "voiceHistory",
        "voiceDictionary",
        "voiceHistoryRelations",
        "voiceDictionaryRelations"
      ]
    },
    {
      "file": "lib/db/sqlite-workflows-schema.ts",
      "exports": [
        "agentWorkflowsRelations",
        "agentWorkflowMembersRelations"
      ]
    },
    {
      "file": "lib/db/sqlite-schedule-schema.ts",
      "exports": [
        "scheduledTasksRelations",
        "scheduledTaskRunsRelations"
      ]
    },
    {
      "file": "lib/ai/providers/codex-session-store.ts",
      "exports": [
        "getActiveSessionIds",
        "getSessionCount",
        "clearAllSessions"
      ]
    },
    {
      "file": "lib/ai/providers/codex-ws-gate.ts",
      "exports": [
        "getActiveWsCount",
        "getActiveWsTickets",
        "releaseAllWs"
      ]
    },
    {
      "file": "lib/plugins/registry.ts",
      "exports": [
        "getPluginById",
        "getPluginByName",
        "updatePluginStatus",
        "uninstallPlugin",
        "updateMarketplaceCatalog",
        "loadActivePluginHooks"
      ]
    },
    {
      "file": "lib/plugins/mcp-integration.ts",
      "exports": [
        "disconnectPluginMCPServers",
        "loadAllPluginMCPServers"
      ]
    },
    {
      "file": "lib/agents/workflow-folder-sharing.ts",
      "exports": ["syncOwnFoldersToWorkflowMembers", "cleanupInheritedFoldersOnRemoval"]
    },
    {
      "file": "lib/vectordb/shared-folder-registry.ts",
      "exports": ["resolveRegistryPath", "isRegistered"]
    },
    {
      "file": "lib/vectordb/sync-scheduler.ts",
      "exports": ["isSyncingPath", "cancelSyncByPath"]
    },
    {
      "file": "lib/voice/voice-utils.ts",
      "exports": ["buildWhisperPromptFromDictionary"]
    }
  ]
}
